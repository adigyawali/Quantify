# Copy to .env for local development. Set the real values in Azure App
# Service → Configuration → Application Settings for production.

# Required — JWT signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Required — Finnhub API key (free tier works). Sign up at finnhub.io
FINNHUB_API_KEY=

# Optional — Alpha Vantage is a fallback source for intraday bars.
ALPHA_VANTAGE_KEY=

# Required in production — comma-separated origins allowed to call the API.
# Example: https://tickr-prod.azurewebsites.net,https://tickr.app
ALLOWED_ORIGINS=http://localhost:3000

# Optional — JWT lifetime in hours (default 12)
JWT_TTL_HOURS=12

# Optional — set to 1 in production behind HTTPS to send HSTS header
FORCE_HSTS=0

# Optional — DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Azure-specific persistent paths (set automatically in startup.sh)
# DATABASE_FILE_PATH=/home/site/data/userInfo.db
# HF_HOME=/home/.cache/huggingface
