.git
.gitignore
.github
.vscode
.idea
.DS_Store
.env
.env.*
*.log

# Local Python (match at any depth — Docker patterns are root-only without **)
**/__pycache__
**/*.pyc
**/*.pyo
**/venv
**/.venv
**/env
**/.pytest_cache

# Node
client/node_modules

# IMPORTANT: do NOT exclude client/build — Flask serves it.
# Build is committed (see .gitignore !client/build override) or generated
# in CI before `docker build`.

# Local SQLite (Azure App Service mounts a persistent path at /home)
flask-server/userInfo.db
*.db-journal

# Mac
Thumbs.db
